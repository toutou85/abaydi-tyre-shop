 <!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>نظام PNUE الاحترافي</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
<style>

/* ===== TOKENS ===== */
:root {
  --bg:        #0F172A;
  --surface:   #1E293B;
  --surface2:  #263348;
  --border:    #334155;
  --gold:      #F59E0B;
  --gold-dim:  #92400E;
  --text:      #F1F5F9;
  --text-muted:#94A3B8;
  --red:       #EF4444;
  --red-dim:   #7F1D1D;
  --green:     #10B981;
  --radius:    14px;
  --radius-sm: 8px;
  --shadow:    0 4px 24px rgba(0,0,0,0.35);
  --font:      'Tajawal', sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  direction: rtl;
}

/* ===== HEADER ===== */
.header {
  background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
  border-bottom: 1px solid var(--border);
  padding: 20px 24px 16px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo-icon {
  width: 40px; height: 40px;
  background: var(--gold);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
  color: #000;
  font-weight: 800;
  flex-shrink: 0;
}

.logo-text h1 {
  font-size: 18px;
  font-weight: 800;
  color: var(--text);
  line-height: 1;
}

.logo-text span {
  font-size: 11px;
  color: var(--text-muted);
}

.stats-bar {
  display: flex;
  gap: 10px;
}

.stat-chip {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 5px 14px;
  font-size: 12px;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 5px;
}

.stat-chip b {
  color: var(--gold);
  font-size: 14px;
}

/* ===== CONTROLS ===== */
.controls {
  display: flex;
  gap: 8px;
  padding: 14px 24px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
}

.search-wrap {
  flex: 1;
  min-width: 180px;
  position: relative;
}

.search-wrap input {
  width: 100%;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  padding: 10px 14px 10px 36px;
  outline: none;
  transition: border-color 0.2s;
}

.search-wrap input:focus {
  border-color: var(--gold);
}

.search-icon {
  position: absolute;
  left: 11px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  font-size: 15px;
  pointer-events: none;
}

select {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-family: var(--font);
  font-size: 13px;
  padding: 10px 12px;
  outline: none;
  cursor: pointer;
}

.btn {
  border: none;
  border-radius: var(--radius-sm);
  font-family: var(--font);
  font-size: 13px;
  font-weight: 600;
  padding: 10px 16px;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  transition: all 0.18s;
  white-space: nowrap;
}

.btn-outline {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-muted);
}
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }

.btn-gold {
  background: var(--gold);
  color: #000;
}
.btn-gold:hover { background: #FBBF24; }

.btn-ghost {
  background: var(--surface2);
  color: var(--text-muted);
}
.btn-ghost:hover { color: var(--text); }

/* ===== FILTER TABS ===== */
.filter-tabs {
  display: flex;
  gap: 0;
  background: var(--surface2);
  border-radius: var(--radius-sm);
  padding: 2px;
}

.filter-tabs button {
  background: none;
  border: none;
  color: var(--text-muted);
  font-family: var(--font);
  font-size: 12px;
  font-weight: 500;
  padding: 7px 12px;
  cursor: pointer;
  border-radius: 6px;
  transition: all 0.15s;
  white-space: nowrap;
}

.filter-tabs button.active {
  background: var(--gold);
  color: #000;
}

/* ===== TABLE (Desktop) ===== */
.table-section {
  padding: 16px 24px 24px;
}

.result-info {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.table-wrapper {
  border-radius: var(--radius);
  border: 1px solid var(--border);
  overflow: hidden;
  overflow-x: auto;
}

table {
  width: 100%;
  border-collapse: collapse;
  min-width: 1000px;
}

thead tr {
  background: var(--surface2);
}

th {
  padding: 12px 14px;
  font-size: 12px;
  font-weight: 700;
  color: var(--text-muted);
  text-align: center;
  letter-spacing: 0.5px;
  white-space: nowrap;
  border-bottom: 1px solid var(--border);
}

tbody tr {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
}

tbody tr:last-child { border-bottom: none; }

tbody tr:hover { background: var(--surface2); }

td {
  padding: 11px 14px;
  font-size: 13px;
  color: var(--text);
  text-align: center;
  white-space: nowrap;
}

.badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
}

.badge-note {
  background: rgba(245,158,11,0.15);
  color: var(--gold);
  border: 1px solid rgba(245,158,11,0.3);
}

.badge-nonote {
  background: rgba(148,163,184,0.1);
  color: var(--text-muted);
  border: 1px solid var(--border);
}

.note-preview {
  max-width: 160px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 12px;
  color: var(--text-muted);
  text-align: right;
}

.action-btns {
  display: flex;
  gap: 6px;
  justify-content: center;
}

.btn-sm {
  padding: 5px 10px;
  font-size: 11px;
  border-radius: 6px;
  border: none;
  cursor: pointer;
  font-family: var(--font);
  font-weight: 600;
  transition: all 0.15s;
}

.btn-view {
  background: rgba(245,158,11,0.15);
  color: var(--gold);
  border: 1px solid rgba(245,158,11,0.3);
}
.btn-view:hover { background: rgba(245,158,11,0.3); }

.btn-del {
  background: rgba(239,68,68,0.12);
  color: var(--red);
  border: 1px solid rgba(239,68,68,0.25);
}
.btn-del:hover { background: rgba(239,68,68,0.3); }

/* ===== EMPTY STATE ===== */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: var(--text-muted);
}

.empty-state .icon { font-size: 48px; margin-bottom: 12px; }
.empty-state p { font-size: 15px; }

/* ===== LOAD MORE ===== */
.load-more {
  text-align: center;
  padding: 16px;
}

/* ===== CARDS (Mobile) ===== */
.cards-section {
  display: none;
  padding: 12px;
  gap: 12px;
  flex-direction: column;
}

.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px;
  transition: border-color 0.15s;
}

.card:active { border-color: var(--gold); }

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10px;
}

.card-name {
  font-size: 16px;
  font-weight: 700;
  color: var(--text);
}

.card-date {
  font-size: 11px;
  color: var(--text-muted);
}

.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 10px;
}

.card-field {
  background: var(--surface2);
  border-radius: var(--radius-sm);
  padding: 7px 10px;
}

.card-field-label {
  font-size: 10px;
  color: var(--text-muted);
  margin-bottom: 2px;
}

.card-field-value {
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
}

.card-note {
  background: rgba(245,158,11,0.08);
  border: 1px solid rgba(245,158,11,0.2);
  border-radius: var(--radius-sm);
  padding: 8px 10px;
  margin-bottom: 10px;
  font-size: 12px;
  color: var(--gold);
}

.card-actions {
  display: flex;
  gap: 8px;
}

.card-actions button {
  flex: 1;
  padding: 9px;
  font-size: 13px;
  border-radius: var(--radius-sm);
  border: none;
  font-family: var(--font);
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
}

.card-btn-view {
  background: rgba(245,158,11,0.15);
  color: var(--gold);
  border: 1px solid rgba(245,158,11,0.3) !important;
}

.card-btn-del {
  background: rgba(239,68,68,0.1);
  color: var(--red);
  border: 1px solid rgba(239,68,68,0.2) !important;
}

/* ===== MODAL ===== */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  z-index: 9999;
  justify-content: center;
  align-items: flex-end;
  backdrop-filter: blur(4px);
}

.modal-overlay.open {
  display: flex;
}

.modal-box {
  background: var(--surface);
  width: 100%;
  max-width: 500px;
  border-radius: var(--radius) var(--radius) 0 0;
  padding: 20px;
  border: 1px solid var(--border);
  border-bottom: none;
  max-height: 88vh;
  overflow-y: auto;
  animation: slideUp 0.25s ease;
}

@media (min-width: 600px) {
  .modal-overlay {
    align-items: center;
  }
  .modal-box {
    border-radius: var(--radius);
    border-bottom: 1px solid var(--border);
    max-height: 80vh;
  }
}

@keyframes slideUp {
  from { transform: translateY(30px); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}

.modal-handle {
  width: 40px; height: 4px;
  background: var(--border);
  border-radius: 2px;
  margin: 0 auto 16px;
}

.modal-title {
  font-size: 17px;
  font-weight: 700;
  margin-bottom: 14px;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 8px;
}

.notes-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 14px;
  max-height: 220px;
  overflow-y: auto;
}

.note-item {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 10px 12px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
}

.note-body { flex: 1; }
.note-date { font-size: 10px; color: var(--text-muted); margin-bottom: 4px; }
.note-text { font-size: 13px; color: var(--text); line-height: 1.5; }

.note-del-btn {
  background: none;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  font-size: 16px;
  padding: 0;
  line-height: 1;
  flex-shrink: 0;
  transition: color 0.15s;
}
.note-del-btn:hover { color: var(--red); }

.no-notes {
  text-align: center;
  color: var(--text-muted);
  font-size: 13px;
  padding: 20px;
}

.modal-input {
  width: 100%;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  padding: 12px;
  resize: none;
  outline: none;
  margin-bottom: 10px;
  line-height: 1.5;
  transition: border-color 0.2s;
}
.modal-input:focus { border-color: var(--gold); }

.modal-actions {
  display: flex;
  gap: 8px;
}

.modal-actions .btn { flex: 1; justify-content: center; }

/* ===== TOAST ===== */
.toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: var(--surface2);
  color: var(--text);
  border: 1px solid var(--border);
  padding: 11px 22px;
  border-radius: 30px;
  font-size: 13px;
  font-family: var(--font);
  font-weight: 500;
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
  z-index: 99999;
  white-space: nowrap;
  pointer-events: none;
  display: flex;
  align-items: center;
  gap: 7px;
  box-shadow: var(--shadow);
}

.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.toast.success { border-color: var(--green); }
.toast.error   { border-color: var(--red); }

/* ===== MOBILE ===== */
@media (max-width: 768px) {
  .table-section { display: none; }
  .cards-section { display: flex; }

  .controls {
    padding: 10px 12px;
    gap: 7px;
  }

  .header { padding: 14px 14px 12px; }

  .stats-bar { gap: 6px; flex-wrap: wrap; }
  .stat-chip { font-size: 11px; padding: 4px 10px; }

  .btn { padding: 9px 12px; font-size: 12px; }

  .filter-tabs button { padding: 6px 9px; font-size: 11px; }
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }

</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-top">
    <div class="logo">
      <div class="logo-icon">P</div>
      <div class="logo-text">
        <h1>PNUE</h1>
        <span>نظام إدارة العملاء</span>
      </div>
    </div>
    <div class="stats-bar">
      <div class="stat-chip">📋 الكل <b id="countAll">—</b></div>
      <div class="stat-chip">📝 <b id="countNotes">—</b></div>
    </div>
  </div>

  <!-- CONTROLS -->
  <div class="controls" style="padding:0; background:none; border:none; flex-wrap:wrap;">
    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input type="text" id="search" placeholder="بحث بالاسم، الهاتف، الولاية...">
    </div>

    <div class="filter-tabs" id="filterTabs">
      <button class="active" data-val="all">الكل</button>
      <button data-val="has">📝 فيه</button>
      <button data-val="no">🚫 بدون</button>
    </div>

    <button class="btn btn-outline" onclick="showMore()">+ المزيد</button>
    <button class="btn btn-outline" onclick="showAll()">عرض الكل</button>
  </div>
</div>

<!-- TABLE SECTION (Desktop) -->
<div class="table-section">
  <div class="result-info" id="resultInfo"></div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>الاسم</th>
          <th>الهاتف</th>
          <th>الولاية</th>
          <th>البلدية</th>
          <th>العنوان</th>
          <th>المنتج</th>
          <th>التاريخ</th>
          <th>الملاحظات</th>
          <th>إجراء</th>
        </tr>
      </thead>
      <tbody id="tableBody"></tbody>
    </table>
  </div>
  <div class="load-more" id="loadMoreWrap" style="display:none;">
    <button class="btn btn-outline" onclick="showMore()">تحميل المزيد ↓</button>
  </div>
</div>

<!-- CARDS SECTION (Mobile) -->
<div class="cards-section" id="cardsSection"></div>

<!-- MODAL -->
<div class="modal-overlay" id="modal" onclick="handleOverlayClick(event)">
  <div class="modal-box">
    <div class="modal-handle"></div>
    <div class="modal-title">📌 الملاحظات</div>

    <div class="notes-list" id="notesBox"></div>

    <textarea class="modal-input" id="newNote" rows="3" placeholder="اكتب ملاحظة جديدة..."></textarea>

    <div class="modal-actions">
      <button class="btn btn-gold" onclick="addNote()">➕ إضافة</button>
      <button class="btn btn-ghost" onclick="saveNotes()">💾 حفظ</button>
      <button class="btn btn-outline" onclick="closeModal()">✖</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- AUDIO -->
<audio id="soundSuccess" src="sound-success.mp3"></audio>
<audio id="soundDelete"  src="sound-delete.mp3"></audio>

<script>

const API = "https://script.google.com/macros/s/AKfycbzUONDWc43MtRWkyMpoLgAeEXKwLumFTO4A09K-XRcivHyIOO6r10bOH9swU73MNxUIcQ/exec";

let allData      = [];
let limit        = 15;
let filterVal    = "all";
let currentId    = null;
let currentNotes = [];
let searchTimer  = null;

/* ——— UTILS ——— */
const clean = v => (v && v !== "null" && v !== "undefined") ? v : "—";

function getNotes(raw) {
  if (!raw) return [];
  try {
    const p = JSON.parse(raw);
    return Array.isArray(p) ? p : [{text: raw, date:""}];
  } catch { return [{text: raw, date:""}]; }
}

function formatDate(d) {
  if (!d) return "—";
  return new Date(d).toLocaleString('ar-DZ', {
    day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit'
  });
}

function showToast(msg, type="success") {
  const t = document.getElementById("toast");
  t.innerHTML = (type==="success" ? "✅ " : "🗑️ ") + msg;
  t.className = "toast show " + type;
  clearTimeout(t._timer);
  t._timer = setTimeout(() => { t.className = "toast"; }, 2800);
}

function playSuccess() {
  const a = document.getElementById("soundSuccess");
  a.currentTime = 0; a.play().catch(()=>{});
}
function playDelete() {
  const a = document.getElementById("soundDelete");
  a.currentTime = 0; a.play().catch(()=>{});
}

/* ——— LOAD ——— */
function loadData() {
  fetch(API)
    .then(r => r.json())
    .then(data => {
      allData = (data || []).filter(row => {
        const vals = Object.entries(row)
          .filter(([k]) => k !== "id")
          .map(([,v]) => v);
        return vals.some(v => v && v.toString().trim() !== "");
      }).reverse();

      updateStats();
      render();
    });
}

function updateStats() {
  document.getElementById("countAll").textContent   = allData.length;
  document.getElementById("countNotes").textContent = allData.filter(r => getNotes(r.note).length > 0).length;
}

/* ——— FILTER ——— */
document.getElementById("filterTabs").addEventListener("click", e => {
  const btn = e.target.closest("button");
  if (!btn) return;
  filterVal = btn.dataset.val;
  document.querySelectorAll(".filter-tabs button").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
  limit = 15;
  render();
});

document.getElementById("search").addEventListener("input", () => {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => { limit = 15; render(); }, 200);
});

/* ——— RENDER ——— */
function getFiltered() {
  const q = document.getElementById("search").value.toLowerCase().trim();
  return allData.filter(row => {
    const notes = getNotes(row.note);
    if (filterVal === "has" && notes.length === 0) return false;
    if (filterVal === "no"  && notes.length  >  0) return false;
    if (q) {
      const text = Object.values(row).join(" ").toLowerCase();
      if (!text.includes(q)) return false;
    }
    return true;
  });
}

function render() {
  const filtered = getFiltered();
  const sliced   = filtered.slice(0, limit);
  const isMobile = window.innerWidth <= 768;

  document.getElementById("resultInfo").textContent =
    `عرض ${sliced.length} من ${filtered.length} نتيجة`;

  if (isMobile) {
    renderCards(sliced);
  } else {
    renderTable(sliced);
  }

  const lmw = document.getElementById("loadMoreWrap");
  lmw.style.display = (filtered.length > limit) ? "block" : "none";
}

/* TABLE */
function renderTable(rows) {
  if (rows.length === 0) {
    document.getElementById("tableBody").innerHTML =
      `<tr><td colspan="10"><div class="empty-state"><div class="icon">🗂️</div><p>لا توجد نتائج</p></div></td></tr>`;
    return;
  }

  document.getElementById("tableBody").innerHTML = rows.map((row, i) => {
    const notes    = getNotes(row.note);
    const lastNote = notes.length ? notes[notes.length-1].text : "";
    return `
    <tr>
      <td><span style="color:var(--text-muted);font-size:12px;">${i+1}</span></td>
      <td style="font-weight:600;">${clean(row.name)}</td>
      <td style="font-family:monospace;font-size:12px;color:var(--text-muted);">${clean(row.phone)}</td>
      <td>${clean(row.wilaya)}</td>
      <td>${clean(row.commune)}</td>
      <td style="color:var(--text-muted);">${clean(row.adresse)}</td>
      <td><span class="badge badge-note">${clean(row.product)}</span></td>
      <td style="font-size:12px;color:var(--text-muted);">${formatDate(row.date)}</td>
      <td>
        ${notes.length > 0
          ? `<div class="note-preview">${lastNote}</div>
             <span class="badge badge-note" style="margin-top:4px;">${notes.length} ملاحظة</span>`
          : `<span class="badge badge-nonote">لا يوجد</span>`}
      </td>
      <td>
        <div class="action-btns">
          <button class="btn-sm btn-view" onclick="openNotes(${row.id})">👁 عرض</button>
          <button class="btn-sm btn-del"  onclick="deleteRow(${row.id})">❌</button>
        </div>
      </td>
    </tr>`;
  }).join("");
}

/* CARDS */
function renderCards(rows) {
  const sec = document.getElementById("cardsSection");
  if (rows.length === 0) {
    sec.innerHTML = `<div class="empty-state"><div class="icon">🗂️</div><p>لا توجد نتائج</p></div>`;
    return;
  }
  sec.innerHTML = rows.map(row => {
    const notes    = getNotes(row.note);
    const lastNote = notes.length ? notes[notes.length-1].text : null;
    return `
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-name">${clean(row.name)}</div>
          <div class="card-date">${formatDate(row.date)}</div>
        </div>
        ${notes.length > 0
          ? `<span class="badge badge-note">${notes.length} 📝</span>`
          : `<span class="badge badge-nonote">بدون ملاحظات</span>`}
      </div>

      <div class="card-grid">
        <div class="card-field">
          <div class="card-field-label">📞 الهاتف</div>
          <div class="card-field-value" style="font-size:12px;">${clean(row.phone)}</div>
        </div>
        <div class="card-field">
          <div class="card-field-label">📍 الولاية</div>
          <div class="card-field-value">${clean(row.wilaya)}</div>
        </div>
        <div class="card-field">
          <div class="card-field-label">🏘 البلدية</div>
          <div class="card-field-value">${clean(row.commune)}</div>
        </div>
        <div class="card-field">
          <div class="card-field-label">📦 المنتج</div>
          <div class="card-field-value">${clean(row.product)}</div>
        </div>
      </div>

      ${lastNote ? `<div class="card-note">📌 ${lastNote}</div>` : ""}

      <div class="card-actions">
        <button class="card-btn-view" onclick="openNotes(${row.id})">👁 الملاحظات</button>
        <button class="card-btn-del"  onclick="deleteRow(${row.id})">❌ حذف</button>
      </div>
    </div>`;
  }).join("");
}

window.addEventListener("resize", () => render());

/* ——— MORE / ALL ——— */
function showMore() { limit += 15; render(); }
function showAll()  { limit = allData.length; render(); }

/* ——— DELETE ——— */
function deleteRow(id) {
  if (!confirm("هل تريد حذف هذا السجل؟")) return;
  fetch(API, {
    method: "POST",
    body: JSON.stringify({ action:"delete", index: id })
  }).then(() => {
    playDelete();
    showToast("تم الحذف", "error");
    if (navigator.vibrate) navigator.vibrate(80);
    loadData();
  });
}

/* ——— NOTES MODAL ——— */
function openNotes(id) {
  currentId    = id;
  currentNotes = getNotes(allData.find(r => r.id === id)?.note);
  renderNotesModal();
  document.getElementById("modal").classList.add("open");
  document.body.style.overflow = "hidden";
}

function renderNotesModal() {
  const box = document.getElementById("notesBox");
  if (currentNotes.length === 0) {
    box.innerHTML = `<div class="no-notes">لا توجد ملاحظات بعد</div>`;
    return;
  }
  box.innerHTML = currentNotes.map((n, i) => `
    <div class="note-item">
      <div class="note-body">
        <div class="note-date">${n.date || ""}</div>
        <div class="note-text">${n.text}</div>
      </div>
      <button class="note-del-btn" onclick="deleteNote(${i})">×</button>
    </div>
  `).join("");
}

function addNote() {
  const ta   = document.getElementById("newNote");
  const text = ta.value.trim();
  if (!text) return;
  currentNotes.push({
    text,
    date: new Date().toLocaleString('ar-DZ', {
      day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit'
    })
  });
  ta.value = "";
  renderNotesModal();
}

function deleteNote(i) {
  currentNotes.splice(i, 1);
  playDelete();
  showToast("تم حذف الملاحظة", "error");
  if (navigator.vibrate) navigator.vibrate(60);
  renderNotesModal();
}

function saveNotes() {
  fetch(API, {
    method: "POST",
    body: JSON.stringify({
      action: "updateAll",
      index:  currentId,
      field:  "note",
      value:  JSON.stringify(currentNotes)
    })
  }).then(() => {
    playSuccess();
    showToast("تم الحفظ بنجاح");
    if (navigator.vibrate) navigator.vibrate(60);
    loadData();
  });
  closeModal();
}

function closeModal() {
  document.getElementById("modal").classList.remove("open");
  document.body.style.overflow = "";
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById("modal")) closeModal();
}

/* ——— AUDIO UNLOCK ——— */
document.body.addEventListener("click", function unlock() {
  ["soundSuccess","soundDelete"].forEach(id => {
    const a = document.getElementById(id);
    a.play().then(() => { a.pause(); a.currentTime = 0; }).catch(()=>{});
  });
  document.body.removeEventListener("click", unlock);
}, { once: true });

/* ——— START ——— */
loadData();

</script>
</body>
</html>
